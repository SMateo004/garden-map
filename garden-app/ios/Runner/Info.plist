		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>garden_app</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<!-- ── App Transport Security ──────────────────────────────────────────
	     Fuerza HTTPS en todas las conexiones de red.
	     NSAllowsArbitraryLoads = false  → ATS activo (default iOS 9+, explícito aquí)
	     Excepción solo para localhost en builds de debug (simulador).
	───────────────────────────────────────────────────────────────────── -->
		<key>NSAppTransportSecurity</key>
		<dict>
			<key>NSAllowsArbitraryLoads</key>
			<false/>
			<key>NSExceptionDomains</key>
			<dict>
				<!-- API de producción: HTTPS requerido, sin forward secrecy relajada -->
				<key>garden-api-1ldd.onrender.com</key>
				<dict>
					<key>NSExceptionAllowsInsecureHTTPLoads</key>
					<false/>
					<key>NSIncludesSubdomains</key>
					<true/>
				</dict>
				<!-- Cloudinary: HTTPS requerido -->
				<key>res.cloudinary.com</key>
				<dict>
					<key>NSExceptionAllowsInsecureHTTPLoads</key>
					<false/>
					<key>NSIncludesSubdomains</key>
					<true/>
				</dict>
				<!-- Simulador / desarrollo local: permite HTTP solo en localhost -->
				<key>localhost</key>
				<dict>
					<key>NSExceptionAllowsInsecureHTTPLoads</key>
					<true/>
					<key>NSIncludesSubdomains</key>
					<false/>
				</dict>
			</dict>
		</dict>
		<key>UIStatusBarHidden</key>
		<true/>
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<false/>
		<key>FacebookAppID</key>
		<string>1517506836633363</string>
		<key>FacebookClientToken</key>
		<string>a75e25008bc9176f0345a7b276b42c9b</string>
		<key>FacebookDisplayName</key>
		<string>Garden</string>
		<key>CFBundleURLTypes</key>
		<array>
			<!-- Facebook Login -->
			<dict>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>fb1517506836633363</string>
				</array>
			</dict>
			<!-- Firebase / Google Sign-In — requerido para reCAPTCHA en simulador
			     y para el flujo de verificación de teléfono de Firebase Auth.
			     Valor = REVERSED_CLIENT_ID de GoogleService-Info.plist -->
			<dict>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>com.googleusercontent.apps.1067635397531-kf2csers9d0veh5s4ioeiitemlg5rigf</string>
				</array>
			</dict>
		</array>
		<key>LSApplicationQueriesSchemes</key>
		<array>
			<string>fbapi</string>
			<string>fb-messenger-share-api</string>
		</array>
		<key>NSLocalNetworkUsageDescription</key>
		<string>Se usa para detectar dispositivos en la red local durante el desarrollo.</string>
		<key>NSBonjourServices</key>
		<array>
			<string>_dartobservatory._tcp</string>
		</array>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>GARDEN necesita acceso a tu galería para subir fotos de tus mascotas.</string>
		<key>NSCameraUsageDescription</key>
		<string>GARDEN necesita acceso a tu cámara para tomar fotos de tus mascotas.</string>
		<key>NSPhotoLibraryAddUsageDescription</key>
		<string>GARDEN necesita permiso para guardar fotos en tu galería.</string>
	</dict>
</plist>
