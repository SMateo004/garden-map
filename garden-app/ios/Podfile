platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

target 'GardenActivityWidgetExtension' do
  use_frameworks!
  inherit! :search_paths
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      config.build_settings['CODE_SIGN_IDENTITY'] = ''
    end
  end
  # Fix build-phase cycle caused by CocoaPods embedding the widget extension,
  # and fix Xcode 26 cycle where Thin Binary declares INFOPLIST_PATH as input.
  # Both fixes run on every pod install so Flutter can't re-introduce them.
  # Also injects a Run Script phase into GardenActivityWidgetExtension that strips
  # macOS extended attributes (iCloud adds them at write time) right before codesign.
  installer.aggregate_targets.each do |aggregate_target|
    project = aggregate_target.user_project
    project.targets.each do |target|
      target.build_phases.each do |build_phase|
        next unless build_phase.respond_to?(:name)
        # Remove GardenActivityWidget from CP embed phase (widget extension cycle)
        if build_phase.name == '[CP] Embed Pods Frameworks'
          build_phase.input_paths&.delete_if  { |p| p.include?('GardenActivityWidget') }
          build_phase.output_paths&.delete_if { |p| p.include?('GardenActivityWidget') }
        end
        # Remove INFOPLIST_PATH input from Thin Binary (Xcode 26 ExtractAppIntentsMetadata cycle)
        if build_phase.name == 'Thin Binary'
          build_phase.input_paths&.delete_if  { |p| p.include?('INFOPLIST_PATH') }
        end
      end

      # (no additional signing override needed — iCloud issue resolved via build/ symlink)
    end
    project.save
  end
  # Strip macOS extended attributes (com.apple.quarantine, com.apple.fileprovider.dir#N, etc.)
  # that cause "resource fork, Finder information, or similar detritus not allowed" codesign errors.
  # Pods: only frameworks (some pod source files are read-only, xattr -cr would fail on them).
  Dir.glob(File.join(installer.sandbox.root, '**', '*.framework')).each do |framework|
    system("xattr -cr '#{framework}'")
  end
  # Widget extension source, Runner source, and flutter build output: safe to clean entirely.
  [
    File.expand_path(File.join('..', 'GardenActivityWidget'), __FILE__),
    File.expand_path(File.join('..', 'Runner'), __FILE__),
    File.expand_path(File.join('..', '..', 'build'), __FILE__),
  ].each do |dir|
    system("xattr -cr '#{dir}'") if File.exist?(dir)
  end

  # PostHog bundles PHPLCrashReporter but the vendor/Source headers are missing from the pod.
  # Create a stub CrashReporter.h so the module.modulemap resolves and the build succeeds.
  # Crash reporting via PLCrashReporter won't function, but all other PostHog features work.
  crash_reporter_dir = File.join(installer.sandbox.root, 'PostHog', 'vendor', 'PHPLCrashReporter', 'Source')
  unless File.exist?(File.join(crash_reporter_dir, 'CrashReporter.h'))
    FileUtils.mkdir_p(crash_reporter_dir)
    File.write(File.join(crash_reporter_dir, 'CrashReporter.h'), "// stub header — PLCrashReporter vendor files not shipped in this pod version\n")
    puts "PostHog: created stub CrashReporter.h at #{crash_reporter_dir}"
  end
end
