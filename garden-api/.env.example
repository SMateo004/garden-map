NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://user:password@localhost:5432/garden_db"
JWT_SECRET=tu-secreto-largo-aqui-minimo-32-caracteres-genera-uno-seguro
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters
JWT_REFRESH_EXPIRES_IN=30d
# Cloudinary (opcional): sin estas variables, en desarrollo el wizard de fotos usa URLs placeholder.
# Para subida real de fotos, crea una cuenta en cloudinary.com y rellena:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email verification (Resend preferred; or SMTP fallback)
RESEND_API_KEY=re_...
EMAIL_FROM=GARDEN <onboarding@resend.dev>
# SMTP fallback (e.g. Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
