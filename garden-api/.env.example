# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/garden_db"

# Prisma connection pool (appended to DATABASE_URL automatically if not present)
# DB_POOL_SIZE=10       # max connections per API instance (default: 10)
# DB_POOL_TIMEOUT=30    # seconds to wait before pool timeout (default: 30)

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET=tu-secreto-largo-aqui-minimo-32-caracteres-genera-uno-seguro
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (Resend — required for verification emails) ────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=GARDEN <onboarding@resend.dev>

# ── Cloudinary (image uploads) ───────────────────────────────────────────────
# Create a free account at cloudinary.com. Without these vars the wizard uses
# local file storage in development.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Redis (cache + Socket.io adapter) ───────────────────────────────────────
# Optional. Without Redis the API falls back to in-memory cache (single-instance only).
# REDIS_URL=redis://localhost:6379

# ── Observability ───────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...      # Error monitoring (optional)
# POSTHOG_API_KEY=phc_...                   # Product analytics (optional)

# ── Stripe (payments) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS Rekognition (identity verification) ──────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# ── App URLs ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info

# ── Blockchain (Polygon Amoy testnet — optional) ─────────────────────────────
# BLOCKCHAIN_ENABLED=false
# BLOCKCHAIN_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
# BLOCKCHAIN_PRIVATE_KEY=your_private_key_without_0x
# BLOCKCHAIN_CONTRACT_ADDRESS=0x...
# BLOCKCHAIN_PROFILES_ADDRESS=0x...
