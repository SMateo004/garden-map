generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                        @id @default(uuid())
  email                        String                        @unique
  passwordHash                 String
  role                         UserRole
  activeRole                   UserRole?
  firstName                    String
  lastName                     String
  phone                        String                        @unique
  isDeleted                    Boolean                       @default(false)
  deletedAt                    DateTime?
  fcmToken                     String?
  profilePicture               String?
  country                      String?
  city                         String?
  /// Código único de la tarjeta de donador — se genera solo la primera vez
  /// que el cliente abre esa tarjeta en la billetera (lazy), fijo de por
  /// vida. Se muestra en el reverso de la tarjeta para canjear descuentos
  /// en veterinarias/negocios asociados.
  donorCode                    String?                       @unique
  isOver18                     Boolean                       @default(true)
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  dateOfBirth                  DateTime?                     @db.Date
  emailVerified                Boolean                       @default(false)
  identityVerified             Boolean                       @default(false)
  clientBookings               Booking[]                     @relation("ClientBookings")
  caregiverProfile             CaregiverProfile?
  clientProfile                ClientProfile?
  identityVerificationSessions IdentityVerificationSession[]
  reviews                      Review[]
  verificationAudits           VerificationAudit[]
  emailVerifications           EmailVerification[]
  notifications                Notification[]
  sentMessages                 ChatMessage[]
  walletTransactions           WalletTransaction[]
  donations                    Donation[]
  donorCodeRedemptions         DonorCodeRedemption[]
  featureFlags                 UserFeatureFlag[]             @relation("UserFeatureFlags")
  refreshTokens                RefreshToken[]
  passwordResets               PasswordReset[]
  passwordResetCodes           PasswordResetCode[]
  /// Usuarios que este usuario ha bloqueado (chat).
  blockedUsers                 UserBlock[]                   @relation("BlockerUser")
  /// Usuarios que han bloqueado a este usuario (chat).
  blockedByUsers               UserBlock[]                   @relation("BlockedUser")
  chatReportsMade              ChatReport[]                  @relation("ChatReportsMade")
  chatReportsReceived          ChatReport[]                  @relation("ChatReportsReceived")
  /// Billetera unificada: saldo disponible para retiro o pago de reservas.
  /// Única fuente de verdad independientemente del rol (CLIENT, CAREGIVER o ambos).
  balance                      Decimal                       @default(0) @db.Decimal(10, 2)
  /// Datos bancarios para retiros (aplica para CLIENT y CAREGIVER). Modalidad "transferencia bancaria".
  bankName                     String?                       @db.VarChar(100)
  bankAccount                  String?                       @db.VarChar(50)
  bankHolder                   String?                       @db.VarChar(100)
  bankType                     BankAccountType?
  /// Modalidad de retiro preferida: transferencia bancaria (default) o QR de cobro propio.
  withdrawalMethod             WithdrawalMethod              @default(BANK_TRANSFER)
  withdrawalQrs                WithdrawalQr[]
  phoneOtp                     String?                       @db.VarChar(6)
  phoneOtpExpiresAt            DateTime?

  @@index([email])
  @@index([role])
  @@index([phone])
  @@map("users")
}

/// Historial de QR de cobro que el cliente/cuidador sube para la modalidad de
/// retiro "QR de transferencia" (su propio QR de cobro personal, generado por
/// su banco/billetera). Se mantiene historial (en vez de un solo campo en
/// User) con flag `isCurrent` para poder auditar qué QR se usó para pagar un
/// retiro ya procesado ante una disputa — este proyecto ya tuvo incidentes de
/// datos de dinero mal manejados (ver CLAUDE.md), así que preferimos no perder
/// el rastro de versiones anteriores.
model WithdrawalQr {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl  String
  /// true = el QR vigente a usar para el próximo retiro. Al subir uno nuevo,
  /// el anterior se marca isCurrent=false en vez de borrarse.
  isCurrent Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, isCurrent])
  @@map("withdrawal_qrs")
}

model CaregiverProfile {
  id                              String                      @id @default(uuid())
  userId                          String                      @unique
  /// Campo canónico de estado del cuidador. Flujo: DRAFT→PENDING_REVIEW→(APPROVED|REJECTED|NEEDS_REVISION)→SUSPENDED.
  status                          CaregiverStatus             @default(DRAFT)
  /// Legacy: redundante con status=APPROVED. Se mantiene por compatibilidad con queries existentes.
  verified                        Boolean                     @default(false)
  verifiedAt                      DateTime?
  verifiedBy                      String?
  verificationNotes               String?
  /// Legacy: redundante con status. Mantiene el detalle del sub-estado de revisión de identidad del admin.
  verificationStatus              VerificationStatus          @default(PENDING_REVIEW)
  rejectionReason                 String?
  adminNotes                      String?
  approvedAt                      DateTime?
  approvedBy                      String?
  reviewedAt                      DateTime?
  /// Legacy: redundante con status=SUSPENDED. Se mantiene por compatibilidad.
  suspended                       Boolean                     @default(false)
  suspendedAt                     DateTime?
  suspensionReason                String?
  rating                          Float                       @default(0)
  reviewCount                     Int                         @default(0)
  bio                             String?                     @db.VarChar(500)
  bioDetail                       String?                     @db.VarChar(300)
  zone                            Zone?
  spaceType                       String[]
  spaceDescription                String?                     @db.VarChar(500)
  photos                          String[] // legacy — reemplazado por caregiverPhotos
  walkerPhotos                    String[]                    @default([]) // legacy
  caregiverPhotos                 String[] // fotos del cuidador en acción (min 2, max 6 — todos los servicios)
  placePhotos                     Json? // { sala:[url], descanso:[url], alimentacion:[url], jardin:[url], juego:[url] }
  profilePhoto                    String?
  address                         String?                     @db.VarChar(500)
  addressLat                      Float?
  addressLng                      Float?
  addressStreet                   String?                     @db.VarChar(200)
  addressNumber                   String?                     @db.VarChar(20)
  addressApartment                String?                     @db.VarChar(50)
  addressCondominio               String?                     @db.VarChar(100)
  addressReference                String?                     @db.VarChar(200)
  addressZone                     String?                     @db.VarChar(100)
  /// Ciudad/zona reales (multi-ciudad) — reemplazan gradualmente el enum
  /// `zone` fijo a Santa Cruz. Nullable por ahora para no romper perfiles
  /// existentes; se migran con un script aparte.
  cityId                          String?
  city                            City?                       @relation(fields: [cityId], references: [id])
  zoneId                          String?
  cityZone                        CityZone?                   @relation(fields: [zoneId], references: [id])
  servicesOffered                 ServiceType[]
  serviceAvailability             Json?
  pricePerDay                     Int?
  pricePerWalk30                  Int?
  pricePerWalk60                  Int?
  pricePerGuarderia               Float?
  guarderiaIncludeWalk            Boolean                     @default(false)
  rates                           Json?
  termsAccepted                   Boolean?
  privacyAccepted                 Boolean?
  verificationAccepted            Boolean?
  termsAcceptedAt                 DateTime?
  experienceYears                 Int?
  ownPets                         Boolean?
  currentPetsDetails              Json?
  caredOthers                     Boolean?
  animalTypes                     AnimalType[]
  experienceDescription           String?                     @db.Text
  whyCaregiver                    String?                     @db.Text
  whatDiffers                     String?                     @db.Text
  handleAnxious                   String?                     @db.Text
  emergencyResponse               String?                     @db.Text
  acceptAggressive                Boolean?
  acceptMedication                MedicationType[]
  acceptPuppies                   Boolean?
  acceptSeniors                   Boolean?
  /// Si es true, el cuidador exige completar un Meet & Greet antes de
  /// confirmar cualquier reserva nueva con un cliente.
  requireMeetAndGreet             Boolean                     @default(false)
  sizesAccepted                   String[]
  noAcceptBreeds                  Boolean?
  breedsWhy                       String?                     @db.VarChar(500)
  homeType                        HomeType?
  ownHome                         Boolean?
  hasYard                         Boolean?
  yardFenced                      Boolean?
  hasChildren                     Boolean?
  hasOtherPets                    Boolean?
  petsSleep                       PetsSleep?
  clientPetsSleep                 ClientPetsSleep?
  hoursAlone                      Int?
  workFromHome                    Boolean?
  maxPets                         Int?
  oftenOut                        Boolean?
  typicalDay                      String?
  /// CI anverso (frontal): obligatorio para enviar solicitud y PENDING_REVIEW. Subida a Cloudinary (garden/ci).
  ciAnversoUrl                    String?
  /// CI reverso (trasero): obligatorio para enviar solicitud y PENDING_REVIEW. Subida a Cloudinary (garden/ci).
  ciReversoUrl                    String?
  /// Número de CI (obligatorio y único para prevención de fraude)
  ciNumber                        String?                     @unique @db.VarChar(50)
  /// Horario predeterminado para disponibilidad: { hospedajeDefault?: boolean, paseoTimeBlocks?: { MANANA, TARDE, NOCHE } }
  defaultAvailabilitySchedule     Json?
  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt
  /// Onboarding: { step: number, completed: boolean[] } — paso actual y completados
  onboardingStatus                Json?
  /// Identity status: PENDING | REVIEW | VERIFIED | REJECTED
  identityVerificationStatus      String?                     @default("PENDING") @db.VarChar(20)
  /// Token for verification URL
  identityVerificationToken       String?                     @unique @db.VarChar(64)
  identityVerificationScore       Float?
  identityVerificationSubmittedAt DateTime?
  emailVerified                   Boolean                     @default(false)
  phoneVerified                   Boolean                     @default(false)
  /// Lifecycle del onboarding visto desde el cuidador: INCOMPLETE | SUBMITTED | UNDER_REVIEW | APPROVED.
  /// Complementa a status (que es la vista del admin). Se actualiza en checkAndAutoSubmitProfile.
  profileStatus                   String?                     @default("INCOMPLETE") @db.VarChar(20)
  /// Flags granulares de completitud calculados por el servidor. Usados para mostrar progreso en el wizard.
  availabilityComplete            Boolean                     @default(false)
  caregiverProfileComplete        Boolean                     @default(false)
  /// true = no tiene capacitaciones AMATEUR obligatorias pendientes (o no es
  /// amateur). Recalculado cada vez que cambia su progreso de capacitación,
  /// sus servicios ofrecidos, o un admin activa/exime un tema. Se filtra
  /// directamente en el marketplace — evita recalcular con joins en cada
  /// búsqueda de cuidadores.
  trainingComplete                Boolean                     @default(true)
  /// Se setea la primera (y única) vez que se envía el correo de recordatorio
  /// de capacitación pendiente — el correo va una sola vez por cuidador, a
  /// diferencia de la notificación in-app que el job diario reenvía todos
  /// los días mientras siga pendiente.
  trainingReminderEmailSentAt     DateTime?
  personalInfoComplete            Boolean                     @default(false)
  addressDetail                   String?                     @db.VarChar(500)
  balance                         Decimal                     @default(0) @db.Decimal(10, 2)
  /// Legacy — deprecado en favor de User.bank* (única fuente de verdad para retiros). Se
  /// mantiene en sync de solo-escritura por compatibilidad con queries admin existentes.
  bankName                        String?                     @db.VarChar(100)
  bankAccount                     String?                     @db.VarChar(50)
  bankHolder                      String?                     @db.VarChar(100)
  bankType                        BankAccountType?
  verificationAttempts            Int                         @default(0)
  verificationLockUntil           DateTime?
  /// Detalles adicionales del servicio (JSON): allowsLargePets, acceptsMultiple, etc.
  serviceDetails                  Json?
  /// Checklist items when admin requests revision (e.g. "Foto borrosa", "Documento no legible")
  reviewChecklist                 Json?                       @db.JsonB
  /// true = cuidador profesional registrado con código de admin (omite verificación CI, aprobado automáticamente)
  isProfessional                  Boolean                     @default(false)
  /// true = empresa (hotel, hostal, guardería, etc.) registrada con código de empresa
  isCompany                       Boolean                     @default(false)
  /// Nombre comercial de la empresa (solo cuando isCompany=true)
  companyName                     String?                     @db.VarChar(200)
  /// Tipo de negocio: HOTEL | HOSTAL | GUARDERIA | PET_HOTEL | OTHER
  businessType                    String?                     @db.VarChar(50)
  /// true = sin experiencia previa (experienceYears === 0 al registrarse).
  /// Se recalcula dinámicamente: si approvedAt >= 1 año, se actualiza a false automáticamente.
  isAmateur                       Boolean                     @default(false)
  /// Número total de incumplimientos registrados (advertencias + multas).
  infractionCount                 Int                         @default(0)
  /// Contactos de emergencia obligatorios (1-3): [{ name: string, phone: string }].
  /// Requerido por Términos y Condiciones Sección 17 antes de ofrecer Hospedaje/Guardería.
  emergencyContacts               Json?
  availability                    Availability[]
  bookings                        Booking[]                   @relation("CaregiverBookings")
  user                            User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews                         Review[]
  sugerencias                     SugerenciaPrecio[]
  infractions                     CaregiverInfraction[]
  trainingProgress                CaregiverTrainingProgress[]
  extraServices                   ExtraService[]

  @@index([status])
  @@index([userId])
  @@index([zone, verified])
  @@index([verified])
  @@index([zone, verified, suspended])
  @@index([verified, suspended])
  @@index([verificationStatus])
  @@index([rating(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([experienceYears])
  @@index([animalTypes])
  @@map("caregiver_profiles")
}

/// Disponibilidad por cuidador y fecha. MVP: hospedaje por día; paseos por bloques (MANANA/TARDE/NOCHE).
model Availability {
  id             String           @id @default(uuid())
  caregiverId    String
  /// Fecha del día (sin hora); para consultas de calendario.
  date           DateTime         @db.Date
  /// false = bloqueado (no acepta reservas ese día).
  isAvailable    Boolean          @default(true)
  /// Solo paseos: bloques de tiempo. Ej: { "MANANA": true, "TARDE": true, "NOCHE": false } (TimeSlot).
  timeBlocks     Json?
  /// Motivo opcional de no disponibilidad o cambio en esa fecha.
  overrideReason String?
  createdAt      DateTime         @default(now())
  caregiver      CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@unique([caregiverId, date])
  @@index([caregiverId])
  @@index([caregiverId, date])
  @@index([date, isAvailable])
  @@map("availability")
}

/// Reserva: hospedaje (48h mínima) o paseo (30/60 min, bloques MANANA/TARDE/NOCHE).
/// Flujo: PENDING_PAYMENT → (pago) → CONFIRMED → IN_PROGRESS → COMPLETED.
/// Cancelación: cliente (refund según política) o cuidador solicita → admin aprueba (CANCELLED).
model Booking {
  id                         String           @id @default(uuid())
  clientId                   String
  caregiverId                String
  serviceType                ServiceType
  status                     BookingStatus    @default(PENDING_PAYMENT)
  startDate                  DateTime?        @db.Date
  endDate                    DateTime?        @db.Date
  totalDays                  Int?
  walkDate                   DateTime?        @db.Date
  timeSlot                   TimeSlot?
  startTime                  String?          @db.VarChar(5)
  duration                   Int?
  walkDays                   Json?            @db.JsonB // multi-day paseo: [{ date, timeSlot, startTime? }]
  petId                      String?
  petCount                   Int              @default(1) // total mascotas en esta reserva (para chequeo de capacidad)
  petName                    String           @db.VarChar(200) // nombre(s) separados por coma
  petBreed                   String?          @db.VarChar(100)
  petAge                     Int?
  petSize                    PetSize?
  specialNeeds               String?
  totalAmount                Decimal          @db.Decimal(10, 2)
  pricePerUnit               Decimal          @db.Decimal(10, 2)
  commissionAmount           Decimal          @db.Decimal(10, 2)
  stripeCheckoutSessionId    String?          @unique
  stripePaymentIntentId      String?
  stripeEventId              String?          @unique // Idempotencia: un evento Stripe no se procesa dos veces
  qrId                       String?          @unique
  qrImageUrl                 String?          @db.Text // Base64 image from SIP or URL
  qrExpiresAt                DateTime?
  /// Se marca cada vez que se genera un QR o se pide aprobación manual —
  /// arranca la ventana de 24h en la que el admin puede usar "Aprobar pago"
  /// desde el detalle de la reserva (control de casos especiales).
  paymentApprovalRequestedAt DateTime?
  sipQrId                    String? // idQr returned by SIP after generating QR
  sipTransaccionId           String? // idTransaccion returned by SIP
  paidAt                     DateTime?
  cancelledAt                DateTime?
  cancellationReason         String?
  cancellationSource         String?          @db.VarChar(30)
  refundAmount               Decimal?         @db.Decimal(10, 2)
  refundStatus               RefundStatus?
  createdAt                  DateTime         @default(now())
  /// true solo si esta reserva la creó un admin a mano (herramienta de
  /// pruebas, sin pasar por el flujo real de pago/Meet&Greet). Habilita el
  /// botón de borrado directo — nunca se puede borrar una reserva real.
  createdByAdmin             Boolean          @default(false)
  serviceStartedAt           DateTime?
  serviceEndedAt             DateTime?
  serviceStartPhoto          String?
  serviceEndPhoto            String?
  /// Momento en que el DUEÑO marca (desde su lado) que el servicio ya terminó.
  /// Si esto ocurre antes de que el cuidador concluya oficialmente (con fotos),
  /// el overtime se congela en este instante en vez de seguir corriendo hasta
  /// que el cuidador finalmente suba sus fotos — evita que el overtime dependa
  /// solo de cuándo el cuidador decide cerrar el servicio.
  clientMarkedEndAt          DateTime?
  /// Último recordatorio push enviado a ambas partes cuando el servicio sigue
  /// IN_PROGRESS pasado el horario acordado + gracia y nadie lo marcó como
  /// terminado. Throttle para no reenviar en cada corrida del job.
  lastEndReminderAt          DateTime?
  serviceTrackingData        Json?            @db.JsonB
  gpsDistance                Float?
  serviceEvents              Json?            @db.JsonB
  /// Momento en que empezó la pausa actual por emergencia (INCIDENT/ACCIDENT
  /// reportado por el cuidador) — null si no está pausado ahora mismo. Única
  /// excepción donde el tiempo del servicio se congela (ver calcOvertimeMinutes).
  pausedAt                   DateTime?
  /// Minutos acumulados pausados durante toda la vida del booking (puede haber
  /// más de una emergencia) — se resta del cálculo de overtime.
  totalPausedMinutes         Int              @default(0)
  ownerRated                 Boolean          @default(false)
  ownerRating                Int?
  ownerComment               String?          @db.Text
  /// Chips de cualidades del cuidador (Amable, Puntual, Responsable, Respetuoso,
  /// Buena comunicación) que el dueño puede marcar al calificar — alimenta la
  /// reputación del cuidador. Selección múltiple, ninguna obligatoria.
  caregiverSkillTags         String[]         @default([])
  caregiverRated             Boolean          @default(false)
  caregiverRating            Int?
  caregiverComment           String?          @db.Text
  /// Última vez que se envió el recordatorio in-app+push de "calificación
  /// pendiente" al dueño (ver procesarRecordatoriosCalificacion en
  /// service-reminders.job.ts) — evita reenviarlo varias veces dentro de la
  /// misma ventana horaria de detección.
  ratingReminderSentAt       DateTime?
  blockchainTxHash           String?
  blockchainFinalizedTxHash  String?
  blockchainCancelledTxHash  String?
  payoutStatus               String           @default("PENDING")
  /// Monto cubierto por la billetera del cliente al pagar esta reserva. 0 = no usó billetera.
  walletPaymentAmount        Decimal          @default(0) @db.Decimal(10, 2)
  /// Monto extra donado voluntariamente por el cliente al momento del pago, destinado a hogares de perros.
  donationAmount             Decimal?         @db.Decimal(10, 2)
  /// Deuda previa del cliente (saldo negativo) incorporada al monto de este pago.
  /// Se recupera al confirmar el pago — va a GARDEN (el cuidador que generó la deuda ya fue pagado).
  debtRecoveryAmount         Decimal          @default(0) @db.Decimal(10, 2)
  /// Minutos de overtime cobrados al finalizar el servicio (0 si no hubo).
  overtimeMinutes            Int              @default(0)
  /// Monto cobrado al cliente por overtime (Bs).
  overtimeFeeAmount          Decimal          @default(0) @db.Decimal(10, 2)
  updatedAt                  DateTime         @updatedAt
  caregiver                  CaregiverProfile @relation("CaregiverBookings", fields: [caregiverId], references: [id], onDelete: Cascade)
  client                     User             @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  pet                        Pet?             @relation(fields: [petId], references: [id])
  review                     Review?
  dispute                    Dispute?
  serviceReport              ServiceReport?
  messages                   ChatMessage[]
  meetAndGreet               MeetAndGreet?
  bookingPets                BookingPet[]
  donation                   Donation?
  chatReports                ChatReport[]
  bookingExtras              BookingExtra[]

  @@index([clientId, status])
  @@index([caregiverId, status])
  @@index([status])
  @@index([status, startDate])
  @@index([paidAt])
  @@index([petId])
  @@map("bookings")
}

/// Una fila por mascota en una reserva multi-mascota.
/// petIndex = 1 → precio completo; 2 → -25%; 3 → -50%.
model BookingPet {
  id           String   @id @default(uuid())
  bookingId    String
  petId        String?
  petIndex     Int // 1, 2 o 3
  petName      String   @db.VarChar(200)
  petBreed     String?  @db.VarChar(100)
  petAge       Int?
  petSize      PetSize?
  specialNeeds String?
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  pet          Pet?     @relation(fields: [petId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([petId])
  @@map("booking_pets")
}

/// Servicio extra configurable por un cuidador (hoy exclusivo de empresas —
/// isCompany=true — validado en el service, no aquí, para poder abrirlo a
/// cuidadores individuales a futuro sin migración). Se cobra siempre por día.
model ExtraService {
  id            String           @id @default(uuid())
  caregiverId   String
  name          String           @db.VarChar(100)
  pricePerDay   Decimal          @db.Decimal(10, 2)
  /// A qué servicio(s) principal(es) aplica este extra.
  appliesTo     ServiceType[]
  active        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  caregiver     CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  bookingExtras BookingExtra[]

  @@index([caregiverId])
  @@map("extra_services")
}

/// Snapshot de un servicio extra seleccionado en una reserva — conserva
/// nombre/precio del momento de la reserva aunque el ExtraService original
/// cambie o se desactive después.
model BookingExtra {
  id             String        @id @default(uuid())
  bookingId      String
  extraServiceId String?
  name           String        @db.VarChar(100)
  pricePerDay    Decimal       @db.Decimal(10, 2)
  totalPrice     Decimal       @db.Decimal(10, 2)
  booking        Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  extraService   ExtraService? @relation(fields: [extraServiceId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@map("booking_extras")
}

/// Reporte de incumplimiento del cuidador (servicio no iniciado). Emitido por el cliente.
/// Flujo: PENDING → REFUNDED (reembolso automático) | DISMISSED (admin revierte).
model ServiceReport {
  id           String    @id @default(uuid())
  bookingId    String    @unique
  clientId     String // User.id del dueño
  reasons      String[] // motivos seleccionados
  details      String?   @db.Text
  status       String    @default("REFUNDED") // 'REFUNDED' | 'DISMISSED'
  refundAmount Decimal?  @db.Decimal(10, 2)
  refundedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  booking      Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([bookingId])
  @@map("service_reports")
}

/// Registro de advertencias y multas al cuidador por incumplimiento.
/// Primera vez: WARNING (sin multa). Siguientes: FINE (20% del monto de la reserva).
model CaregiverInfraction {
  id            String           @id @default(uuid())
  caregiverId   String // CaregiverProfile.id
  bookingId     String?
  type          String // 'WARNING' | 'FINE'
  fineAmount    Decimal?         @db.Decimal(10, 2) // importe deducido (solo en FINE)
  bookingAmount Decimal?         @db.Decimal(10, 2) // totalAmount de la reserva involucrada
  reasons       String[] // motivos del reporte que generó esto
  notified      Boolean          @default(false)
  createdAt     DateTime         @default(now())
  caregiver     CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@index([caregiverId])
  @@map("caregiver_infractions")
}

model WalletTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // 'EARNING' | 'PAYMENT' | 'REFUND' | 'WITHDRAWAL' | 'COMMISSION'
  amount      Decimal  @db.Decimal(10, 2)
  balance     Decimal  @db.Decimal(10, 2) // saldo después de la transacción
  description String
  bookingId   String?
  status      String   @default("COMPLETED") // 'COMPLETED' | 'PENDING' | 'REJECTED'
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([bookingId])
  @@map("wallet_transactions")
}

model Review {
  id                String           @id @default(uuid())
  bookingId         String           @unique
  clientId          String
  caregiverId       String
  rating            Int?             @db.SmallInt // null = generada por sistema (auto-release), no afecta promedio
  comment           String?
  photo             String?
  serviceType       ServiceType
  caregiverResponse String?
  respondedAt       DateTime?
  isSystemGenerated Boolean          @default(false) // true = auto-release sin calificación del cliente
  createdAt         DateTime         @default(now())
  booking           Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  caregiver         CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  client            User             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([caregiverId, rating])
  @@map("reviews")
}

/// Perfil de cliente (dueño de mascota). Datos generales del dueño; mascotas en Pet[].
/// isComplete = true cuando tiene al menos un Pet con name, size y photoUrl (permite crear reservas).
/// Fotos: petPhoto = URL absoluta Cloudinary (sincronizada con primera mascota); cada Pet.photoUrl también.
model ClientProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  address              String?   @db.VarChar(500)
  addressLat           Float?
  addressLng           Float?
  addressStreet        String?   @db.VarChar(200)
  addressNumber        String?   @db.VarChar(20)
  addressApartment     String?   @db.VarChar(50)
  addressCondominio    String?   @db.VarChar(100)
  addressReference     String?   @db.VarChar(200)
  addressZone          String?   @db.VarChar(100)
  /// Ciudad/zona reales (multi-ciudad) — mismo patrón que CaregiverProfile.
  cityId               String?
  city                 City?     @relation(fields: [cityId], references: [id])
  zoneId               String?
  cityZone             CityZone? @relation(fields: [zoneId], references: [id])
  phone                String?   @db.VarChar(20)
  bio                  String?
  /// URL absoluta Cloudinary de la foto principal de mascota (p. ej. primera mascota).
  petPhoto             String?
  /// true = tiene al menos una mascota completa (name, size, photoUrl); permite reservas.
  isComplete           Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pets                 Pet[]
  /// @deprecated — balance moved to User.balance for unified wallet. Kept for zero-downtime migration.
  balance              Decimal   @default(0) @db.Decimal(10, 2)
  favoriteCaregiverIds String[]  @default([])

  @@index([userId])
  @@index([isComplete])
  @@map("client_profiles")
}

/// Mascota del cliente. Un dueño puede tener varias (relación 1 a muchos con ClientProfile).
/// Las reservas referencian Pet opcionalmente (petId) y guardan copia de datos para historial.
model Pet {
  id              String        @id @default(uuid())
  clientProfileId String
  name            String        @db.VarChar(200)
  breed           String?       @db.VarChar(100)
  age             Int?
  size            PetSize?
  /// Especie de la mascota — solo DOGS o CATS (mismos valores que
  /// CaregiverProfile.animalTypes), para poder validar contra los tipos que
  /// el cuidador acepta al momento de crear una reserva.
  animalType      AnimalType?
  /// Reportado por el dueño — se valida contra CaregiverProfile.acceptAggressive
  /// al crear una reserva.
  isAggressive    Boolean       @default(false)
  photoUrl        String?
  specialNeeds    String?
  notes           String?
  gender          String?       @db.VarChar(10)
  weight          Float?
  color           String?       @db.VarChar(100)
  sterilized      Boolean?
  microchipNumber String?       @db.VarChar(50)
  extraPhotos     String[]
  vaccinePhotos   String[]
  documents       String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  bookings        Booking[]
  bookingPets     BookingPet[]
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId])
  @@map("pets")
}

model AdminAction {
  id         String   @id @default(uuid())
  adminId    String
  actionType String
  targetId   String
  notes      String?
  createdAt  DateTime @default(now())

  @@index([adminId, actionType])
  @@index([targetId])
  @@map("admin_actions")
}

/// Notificaciones para el panel admin (ej. nueva solicitud cuidador, pago manual, cancelación por cuidador).
model AdminNotification {
  id          String    @id @default(uuid())
  type        String
  caregiverId String
  bookingId   String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([type, readAt])
  @@index([caregiverId])
  @@index([bookingId])
  @@map("admin_notifications")
}

/// Donación voluntaria del dueño al momento del pago, destinada al 100% a hogares de perros.
model Donation {
  id                 String    @id @default(uuid())
  bookingId          String    @unique
  clientId           String
  amount             Decimal   @db.Decimal(10, 2)
  createdAt          DateTime  @default(now())
  /// Fecha en que el admin transfirió los fondos al beneficiario. El monto
  /// (`amount`) NUNCA se edita desde el panel de admin — solo se registra
  /// que ya se hizo la transferencia real y hacia quién.
  disbursedAt        DateTime?
  disbursementNote   String?   @db.VarChar(500)
  beneficiaryId      String?
  disbursedByAdminId String?

  booking     Booking              @relation(fields: [bookingId], references: [id])
  client      User                 @relation(fields: [clientId], references: [id])
  beneficiary DonationBeneficiary? @relation(fields: [beneficiaryId], references: [id])

  @@index([disbursedAt])
  @@index([clientId])
  @@index([beneficiaryId])
  @@map("donations")
}

/// Registro de un canje de la tarjeta de donador en una veterinaria/negocio
/// asociado. El negocio no tiene cuenta ni valida nada por su cuenta — anota
/// el uso a mano y se lo comunica a Garden; el admin lo carga acá desde el
/// panel. Puramente informativo, no dispara ningún efecto monetario.
model DonorCodeRedemption {
  id              String   @id @default(uuid())
  userId          String
  businessName    String   @db.VarChar(200)
  redeemedAt      DateTime // fecha real en que se usó el descuento (la informa el negocio)
  createdAt       DateTime @default(now())
  loggedByAdminId String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("donor_code_redemptions")
}

/// Hogar de mascotas / refugio registrado como destinatario de donaciones.
/// Puramente informativo — no tiene login ni acceso a la plataforma.
model DonationBeneficiary {
  id          String   @id @default(uuid())
  name        String
  contactInfo String?  @db.VarChar(300)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  donations Donation[]

  @@map("donation_beneficiaries")
}

model IdentityVerificationSession {
  id                     String    @id @default(uuid())
  userId                 String
  status                 String    @db.VarChar(20)
  similarity             Float?
  selfieUrl              String?
  ciFrontUrl             String?
  expiresAt              DateTime
  createdAt              DateTime  @default(now())
  completedAt            DateTime?
  reviewedBy             String?
  reviewedAt             DateTime?
  faceCroppedDocumentUrl String?
  faceCroppedSelfieUrl   String?
  rejectionReason        String?
  ciBackUrl              String?
  documentConfidence     Float?
  identityScore          Float?
  livenessFrameUrls      Json?
  livenessScore          Float?
  ocrData                Json?
  similarityScore        Float?
  attemptNumber          Int       @default(1)
  behaviorScore          Float?
  deviceDetails          Json?
  deviceFingerprint      String?   @db.VarChar(128)
  docScore               Float?
  faceScore              Float?
  fraudFlags             Json?
  ipAddress              String?   @db.VarChar(45)
  livenessStatus         String?   @db.VarChar(20)
  locationData           Json?
  ocrScore               Float?
  qualityScore           Float?
  trustScore             Float?
  userAgent              String?
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([deviceFingerprint])
  @@index([ipAddress])
  @@map("identity_verification_sessions")
}

model VerificationAudit {
  id                String   @id @default(uuid())
  userId            String
  sessionId         String?
  action            String   @db.VarChar(50)
  status            String   @db.VarChar(20)
  ipAddress         String?  @db.VarChar(45)
  deviceFingerprint String?  @db.VarChar(128)
  trustScore        Float?
  behaviorScore     Float?
  fraudFlags        Json?
  notes             String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceFingerprint])
  @@map("verification_audits")
}

/// Email verification codes (6-digit, 10 min expiry). Max 5 attempts per code.
model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  codeHash  String   @db.VarChar(64)
  /// Código en texto plano — SOLO se guarda cuando el setting global
  /// `otpVisibleToAdminEnabled` está activo (para que el admin pueda verlo
  /// en pruebas). Con el setting apagado queda null, igual que antes.
  plainCode String?  @db.VarChar(6)
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verifications")
}

/// Inbox notifications for users (e.g. caregiver: APPROVED, REJECTED, REVIEW).
model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String    @db.VarChar(200)
  message   String    @db.Text
  type      String    @db.VarChar(20)
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

/// Key-value store for runtime app configuration (no server restart needed).
model AppSettings {
  key       String   @id
  value     String // JSON-stringified value
  updatedAt DateTime @updatedAt
  updatedBy String? // Admin user ID who last changed it

  @@map("app_settings")
}

/// Log of AI agent calls for the admin monitor.
model AgentLog {
  id         String   @id @default(uuid())
  agentType  String   @db.VarChar(50) // 'PRECIO' | 'CALIFICACION' | 'DISPUTA' | 'CUSTOM'
  action     String   @db.VarChar(200)
  input      Json?
  output     Json?
  durationMs Int?
  status     String   @default("SUCCESS") @db.VarChar(20)
  userId     String?
  createdAt  DateTime @default(now())

  @@index([agentType])
  @@index([createdAt])
  @@map("agent_logs")
}

enum UserRole {
  CLIENT
  CAREGIVER
  ADMIN
}

/// Tipo de cuenta/billetera para retiros vía transferencia bancaria.
/// CUENTA_AHORRO / CUENTA_CORRIENTE piden número de cuenta; las billeteras por
/// teléfono (YAPE/ZAS/YOLOPAGO/ALTOKE) piden número de teléfono en su lugar
/// (ver `PHONE_BASED_BANK_TYPES` en bank-info.util.ts).
enum BankAccountType {
  CUENTA_AHORRO
  CUENTA_CORRIENTE
  YAPE
  ZAS
  YOLOPAGO
  ALTOKE
}

/// Modalidad de retiro elegida por el usuario: transferencia bancaria
/// (bankName/bankAccount/bankHolder/bankType) o QR de cobro propio (WithdrawalQr).
enum WithdrawalMethod {
  BANK_TRANSFER
  QR_TRANSFER
}

enum ServiceType {
  HOSPEDAJE
  PASEO
  GUARDERIA
}

enum Zone {
  EQUIPETROL
  URBARI
  NORTE
  LAS_PALMAS
  CENTRO
  REMANZO
  SUR
  URUBO_NORTE
  URUBO_SUR
  OTROS
}

/// Flujo: creación → pago (automático o aprobación admin) → confirmada → en curso → completada.
/// Cancelación: cliente cancela (refund según política) o cuidador solicita → admin aprueba/rechaza.
enum BookingStatus {
  PENDING_MG
  PENDING_PAYMENT
  PAYMENT_PENDING_APPROVAL
  WAITING_CAREGIVER_APPROVAL
  SLOT_CONFLICT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED_BY_CAREGIVER
}

/// Estado del reembolso cuando la reserva se cancela (MVP: ventana 48h hospedaje / 12h paseos).
enum RefundStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PROCESSED
}

enum TimeSlot {
  MANANA
  TARDE
  NOCHE
}

enum AnimalType {
  DOGS
  CATS
  PUPPIES
  SENIORS
  LARGE
  SMALL
  SPECIAL
}

enum MedicationType {
  ORAL
  INJECT
  TOPIC
}

enum PetSize {
  SMALL
  MEDIUM
  LARGE
  GIANT
}

enum HomeType {
  HOUSE
  APARTMENT
}

enum PetsSleep {
  INSIDE
  OUTSIDE
}

enum ClientPetsSleep {
  BED
  CRATE
  SOFA
  FLOOR
}

enum VerificationStatus {
  PENDING_REVIEW
  REVIEW
  APPROVED
  REJECTED
}

/// Flujo completo registro + revisión admin. Reemplaza uso de verified/verificationStatus a largo plazo.
enum CaregiverStatus {
  DRAFT
  PENDING_REVIEW
  NEEDS_REVISION
  APPROVED
  REJECTED
  SUSPENDED
}

/// Ajuste de precios por zona y servicio generado por el agente de precios AI.
/// Permite sobrescribir temporalmente el precio base de una zona (ej. durante temporada alta).
model AjustePrecio {
  id                   String   @id @default(uuid())
  zona                 String
  servicio             String // PASEO | HOSPEDAJE
  multiplicador        Float // factor multiplicador del precio base
  porcentajeAjuste     Int // % de ajuste para mostrar al usuario
  aplicarDesde         DateTime
  aplicarHasta         DateTime
  motivo               String
  explicacionParaDueno String
  cuandoVuelveNormal   String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([zona, servicio])
  @@map("ajuste_precios")
}

/// Mensajes del chat asociado a una reserva. isSystem=true para mensajes automáticos del sistema.
model ChatMessage {
  id         String   @id @default(uuid())
  bookingId  String
  senderId   String
  senderRole String // CLIENT | CAREGIVER
  message    String
  isSystem   Boolean  @default(false)
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([senderId])
  @@map("chat_messages")
}

/// Bloqueo de usuario en el chat — bloquea todo intercambio de mensajes en ambas direcciones.
/// Requerido por las políticas de App Store (1.2 UGC) y Google Play (contenido generado por el usuario).
model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

/// Reporte de un usuario en el chat de una reserva (acoso, spam, contenido inapropiado, etc).
/// Requerido por App Store (1.2 UGC) y Google Play — mecanismo de reporte de contenido/usuarios abusivos.
/// messagesSnapshot guarda copia de los últimos mensajes al momento del reporte, como evidencia
/// (los mensajes podrían editarse/eliminarse después).
model ChatReport {
  id                String    @id @default(uuid())
  bookingId         String
  reporterId        String
  reportedUserId    String
  /// 'HARASSMENT' | 'INAPPROPRIATE_CONTENT' | 'SPAM' | 'SCAM_OR_FRAUD' | 'THREATS' | 'OTHER'
  reason            String
  details           String?   @db.Text
  /// JSON array de los últimos ~20 ChatMessage al momento del reporte.
  messagesSnapshot  String    @db.Text
  /// 'PENDING' | 'REVIEWED' | 'ACTION_TAKEN' | 'DISMISSED'
  status            String    @default("PENDING")
  adminNotes        String?   @db.Text
  reviewedByAdminId String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())

  booking      Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reporter     User    @relation("ChatReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User    @relation("ChatReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@map("chat_reports")
}

model GiftCode {
  id        String    @id @default(uuid())
  code      String    @unique
  amount    Decimal   @db.Decimal(10, 2)
  usedBy    String[]  @default([])
  maxUses   Int       @default(1)
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@map("gift_codes")
}

/// Reunión previa al servicio (conocerse). Flujo real (ver meet-and-greet.service.ts):
/// PROPOSED → ACCEPTED → COMPLETED (con approved:true|false) | CANCELLED.
/// modalidad: IN_PERSON | VIDEO_CALL. proposedBy: userId del cliente o del cuidador.
model MeetAndGreet {
  id             String    @id @default(uuid())
  bookingId      String    @unique
  booking        Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status         String    @default("PENDING_PROPOSAL") // PROPOSED | ACCEPTED | COMPLETED | CANCELLED
  proposedBy     String // userId (cliente o cuidador)
  modalidad      String // IN_PERSON | VIDEO_CALL
  proposedDate   DateTime?
  confirmedDate  DateTime?
  meetingPoint   String?   @db.Text
  caregiverNotes String?   @db.Text
  clientNotes    String?   @db.Text
  approved       Boolean?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("meet_and_greets")
}

/// Sugerencia de precio generada por el agente AI de precios para un cuidador específico.
/// El cuidador puede aceptar (actualiza su precio) o rechazar. Expira automáticamente.
model SugerenciaPrecio {
  id               String           @id @default(uuid())
  caregiverId      String
  serviceType      String // PASEO | HOSPEDAJE
  precioActual     Int
  precioSugerido   Int
  porcentajeCambio Int
  motivo           String
  explicacion      String           @db.Text
  confianza        String // alta | media | baja
  modeloUsado      String // prophet+arima | arima | reglas | claude
  tendencia        String // rising | stable | falling
  status           String           @default("PENDING") // PENDING | ACCEPTED | REJECTED
  expiresAt        DateTime
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  caregiver        CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@map("sugerencia_precios")
}

/// Notificaciones broadcast enviadas por el admin a segmentos de usuarios.
model AdminBroadcastNotification {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(200)
  message     String    @db.Text
  target      String    @db.VarChar(20) // 'ALL' | 'CUIDADORES' | 'DUENOS'
  type        String    @default("SYSTEM") @db.VarChar(30)
  sentCount   Int       @default(0)
  status      String    @default("SENT") @db.VarChar(20) // 'SENT' | 'SCHEDULED' | 'CANCELLED'
  scheduledAt DateTime?
  sentAt      DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([scheduledAt])
  @@map("admin_broadcast_notifications")
}

model Dispute {
  id                String   @id @default(uuid())
  bookingId         String   @unique
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  clientReasons     String[] // razones seleccionadas por el cliente
  caregiverResponse String[] // respuestas seleccionadas por el cuidador
  aiVerdict         String? // 'CLIENT_WINS' | 'CAREGIVER_WINS' | 'PARTIAL'
  aiAnalysis        String?  @db.Text // análisis del agente
  aiRecommendations String?  @db.Text // recomendaciones para el cuidador (JSON array)
  status            String   @default("PENDING_CLIENT") // 'PENDING_CLIENT' | 'PENDING_CAREGIVER' | 'PENDING_AI' | 'RESOLVED' | 'APPEALED'
  resolution        String? // descripción de la resolución
  /// Solo en veredicto PARTIAL: ID del GiftCode emitido al dueño como compensación (20% del neto, uso único)
  discountCodeId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // ── Apelación (Sección 13 de Términos y Condiciones) ─────────────────────
  // Cualquiera de las partes puede apelar el veredicto de la IA dentro de los
  // 5 días hábiles siguientes a `updatedAt` (momento en que se resolvió). La
  // apelación la revisa una persona del equipo de Garden — nunca el sistema
  // automatizado — y su decisión es definitiva.
  appealedBy              String? // 'CLIENT' | 'CAREGIVER' — quién apeló
  appealReason            String?   @db.Text // explicación + descripción de nueva evidencia
  appealedAt              DateTime?
  appealResolution        String?   @db.Text // decisión escrita del admin humano
  appealVerdict           String? // 'CLIENT_WINS' | 'CAREGIVER_WINS' | 'PARTIAL' — puede diferir del veredicto de la IA
  appealResolvedByAdminId String?
  appealResolvedAt        DateTime?
}

/// Password reset tokens (SHA-256 hashed, 1-hour expiry, single use).
model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique // SHA-256 of the raw 32-byte random token
  expiresAt DateTime
  usedAt    DateTime? // null = still valid; non-null = already used
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_resets")
}

/// Código de 4 dígitos para recuperación de contraseña en-app (flujo sin link externo).
model PasswordResetCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String // SHA-256 del código de 4 dígitos
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_codes")
}

/// Refresh tokens opacos para renovación de sesión sin re-login.
/// Cada token se guarda hasheado (SHA-256). Se rota en cada uso.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique // SHA-256 del token en claro (nunca se guarda el raw)
  expiresAt DateTime
  revokedAt DateTime? // null = activo; non-null = revocado (logout o rotación)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

/// AMATEUR: obligatoria antes del primer servicio para cuidadores con 0 años
/// de experiencia declarados (CaregiverProfile.isAmateur). EXPERIENCE: visible
/// para todos los cuidadores del servicio correspondiente, nunca obligatoria.
enum TrainingAudience {
  AMATEUR
  EXPERIENCE
}

/// Tema de capacitación: uno por combinación (servicio, audiencia). Un
/// cuidador que ofrece PASEO y HOSPEDAJE ve como máximo 2 temas AMATEUR
/// (uno por cada servicio que ofrece) — nunca ve el tema de un servicio que
/// no ofrece, aunque sea amateur.
model TrainingTopic {
  id           String                      @id @default(uuid())
  service      ServiceType
  audience     TrainingAudience
  title        String                      @db.VarChar(200)
  /// Breve introducción mostrada antes del video.
  introduction String?                     @db.Text
  videoUrl     String                      @db.VarChar(500) // URL de YouTube
  isActive     Boolean                     @default(true)
  order        Int                         @default(0)
  createdBy    String? // Admin User.id que lo creó
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  questions    TrainingQuestion[]
  progress     CaregiverTrainingProgress[]

  @@unique([service, audience])
  @@index([service])
  @@index([audience])
  @@index([isActive])
  @@map("training_topics")
}

/// Pregunta de opción múltiple del quiz de un tema (3 por tema).
model TrainingQuestion {
  id           String        @id @default(uuid())
  topicId      String
  topic        TrainingTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  text         String        @db.Text
  /// Opciones de respuesta en orden — ej: ["Llamar al veterinario", "Ignorarlo", "..."]
  choices      String[]
  /// Índice (0-based) de la respuesta correcta dentro de `choices`.
  correctIndex Int
  order        Int           @default(0)
  createdAt    DateTime      @default(now())

  @@index([topicId])
  @@map("training_questions")
}

/// Progreso de un cuidador en un tema de capacitación específico.
/// completedAt != null = video visto Y quiz aprobado (o eximido por admin).
model CaregiverTrainingProgress {
  id              String           @id @default(uuid())
  caregiverId     String
  caregiver       CaregiverProfile @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  topicId         String
  topic           TrainingTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  videoWatchedAt  DateTime?
  quizPassed      Boolean          @default(false)
  quizAttempts    Int              @default(0)
  lastQuizScore   Int?
  /// El admin puede eximir a un cuidador puntual de esta capacitación aunque
  /// sea obligatoria para su categoría — override por cuidador, no global.
  exemptedByAdmin Boolean          @default(false)
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([caregiverId, topicId])
  @@index([caregiverId])
  @@index([topicId])
  @@map("caregiver_training_progress")
}

model VetClinic {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String
  lat       Float
  lng       Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Ciudad a la que pertenece — solo para organizar el panel admin; el cálculo
  /// de "más cercana" sigue siendo por distancia real (lat/lng), no por ciudad.
  cityId    String?
  city      City?    @relation(fields: [cityId], references: [id])

  @@index([cityId])
  @@map("vet_clinics")
}

/// Ciudad donde Garden opera. Reemplaza el supuesto implícito de "todo es
/// Santa Cruz" — permite expandir a Cochabamba y otras ciudades sin tocar
/// código, solo agregando datos desde el panel admin.
model City {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  /// slug usado internamente (ej. "santa-cruz", "cochabamba") — estable, no editable desde la UI.
  slug        String   @unique @db.VarChar(50)
  active      Boolean  @default(true)
  centerLat   Float
  centerLng   Float
  defaultZoom Float    @default(13)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zones             CityZone[]
  caregiverProfiles CaregiverProfile[]
  clientProfiles    ClientProfile[]
  vetClinics        VetClinic[]

  @@map("cities")
}

/// Zona dentro de una ciudad (ej. Equipetrol en Santa Cruz, Parque Fidel
/// Anzoátegui en Cochabamba). Reemplaza el enum fijo `Zone` — el admin puede
/// agregar/editar/activar-desactivar zonas de cualquier ciudad sin migración.
model CityZone {
  id        String   @id @default(uuid())
  cityId    String
  /// Slug único dentro de la ciudad (ej. "EQUIPETROL") — usado internamente, no editable.
  key       String   @db.VarChar(60)
  label     String   @db.VarChar(100)
  /// Color hex para mostrar en el mapa (ej. "#4CAF50").
  color     String   @db.VarChar(9)
  lat       Float
  lng       Float
  /// Vértices del polígono a pintar en el mapa del marketplace, en orden
  /// (mínimo 4): [{lat, lng}, ...]. Nullable — zonas viejas sin polígono
  /// siguen mostrándose como marcador simple en lat/lng hasta que se editen.
  points    Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city              City               @relation(fields: [cityId], references: [id], onDelete: Cascade)
  caregiverProfiles CaregiverProfile[]
  clientProfiles    ClientProfile[]

  @@unique([cityId, key])
  @@index([cityId])
  @@map("city_zones")
}

/// Registro de auditoría de todas las acciones importantes del sistema.
/// Se acumula indefinidamente; el endpoint de exportación filtra por mes.
model AuditLog {
  id        String   @id @default(uuid())
  userId    String? // null para acciones de sistema
  action    String   @db.VarChar(80) // ej: BOOKING_CREATED, PAYMENT_APPROVED, PROFILE_SUBMITTED
  entity    String   @db.VarChar(50) // ej: Booking, Payment, CaregiverProfile, User
  entityId  String?  @db.VarChar(100) // id del recurso afectado
  details   String?  @db.Text // JSON con contexto adicional
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Banner configurable que aparece entre tarjetas de cuidadores en el marketplace.
model MarketplaceBanner {
  id          String   @id @default(uuid())
  active      Boolean  @default(false)
  position    Int      @default(0) // índice de inserción en la lista de cuidadores (0 = antes del primero)
  imageUrl    String?  @db.Text // URL imagen de fondo (Cloudinary)
  title       String   @db.VarChar(200)
  subtitle    String?  @db.VarChar(400)
  buttonText  String?  @db.VarChar(100) // null = sin botón
  actionType  String   @default("none") // "url" | "screen" | "none"
  actionValue String?  @db.Text // URL externa o nombre de pantalla Flutter
  sortOrder   Int      @default(0) // para ordenar cuando hay varios activos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, position])
  @@map("marketplace_banners")
}

/// Notificación push masiva con segmentación y soporte de programación.
model MassNotification {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(200)
  message     String    @db.Text
  /// "all" | "clients" | "caregivers" | "zone"
  targetType  String    @default("all") @db.VarChar(20)
  targetZone  String?   @db.VarChar(100) // solo si targetType = "zone"
  scheduledAt DateTime? // null = envío inmediato
  sentAt      DateTime?
  /// "DRAFT" | "SCHEDULED" | "SENDING" | "SENT" | "FAILED"
  status      String    @default("DRAFT") @db.VarChar(20)
  sentCount   Int       @default(0)
  failCount   Int       @default(0)
  createdBy   String    @db.VarChar(100) // admin userId
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@map("mass_notifications")
}

/// Feature flag por usuario — activa funciones experimentales para usuarios específicos.
model UserFeatureFlag {
  id        String    @id @default(uuid())
  userId    String
  flagKey   String    @db.VarChar(100) // ej: "beta_nueva_pantalla_pago"
  enabled   Boolean   @default(true)
  expiresAt DateTime? // null = sin expiración
  createdAt DateTime  @default(now())
  user      User      @relation("UserFeatureFlags", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, flagKey])
  @@index([userId])
  @@index([flagKey])
  @@map("user_feature_flags")
}
