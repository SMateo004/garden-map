# ── GARDEN API — Production Environment ─────────────────────────────────────
# Copy this file to .env on your production host (Render, Railway, etc.)
# and fill in real values. Never commit .env to git.

NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/garden_db
# Pool: Render free tier has ~25 max connections. Keep ≤ 10 per instance.
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-at-least-64-chars-of-random-hex
JWT_REFRESH_SECRET=separate-64-char-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=GARDEN Bolivia <noreply@garden.bo>

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Redis (required for multi-instance Socket.io + cache) ────────────────────
REDIS_URL=redis://default:password@your-redis-host:6379

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
POSTHOG_API_KEY=phc_...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS Rekognition ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=garden-verification-docs

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://garden.bo
API_PUBLIC_URL=https://api.garden.bo
ALLOWED_ORIGINS=https://garden.bo,https://www.garden.bo
LOG_LEVEL=warn

# ── Blockchain (Polygon Mainnet) ──────────────────────────────────────────────
BLOCKCHAIN_ENABLED=false
# BLOCKCHAIN_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# BLOCKCHAIN_PRIVATE_KEY=your_private_key_without_0x
# BLOCKCHAIN_CONTRACT_ADDRESS=0x...
# BLOCKCHAIN_PROFILES_ADDRESS=0x...

# ── Anthropic Claude (AI dispute resolution) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Beta access control (manage via /api/admin/settings) ─────────────────────
# betaInviteRequired — set to "true" via admin API to enforce invite codes
# betaInviteCodes    — JSON array: ["GARDEN2025","BETA01"] via admin API
